# =============================================================================
# HTTPS and Domain Configuration (Caddy)
# =============================================================================

# Domain name for automatic HTTPS with Let's Encrypt
# Leave empty for local development (will use localhost with self-signed cert)
# Example: happy.uni1.de
DOMAIN=meco.uni1.de

# Email for Let's Encrypt certificate notifications
# Required for production when DOMAIN is set
# Leave empty for local development
ACME_EMAIL=admin@meco.uni1.de

# =============================================================================
# Application URLs
# =============================================================================

# Frontend URL (used for CORS and email links)
# For production with HTTPS: https://your-domain.com
# For local development: http://localhost
CLIENT_URL=https://meco.uni1.de

# Backend API URL (used by frontend to make API calls)
# With Caddy reverse proxy, API is accessible at /api/* on same domain
# Caddy strips the /api prefix when forwarding to backend
# For production with HTTPS: https://your-domain.com/api
# For local development: http://localhost/api
VITE_API_URL=https://meco.uni1.de/api

# =============================================================================
# Backend Configuration
# =============================================================================

# Database path (inside container)
DB_PATH=/app/server/data/happyGoLucky.db

# Required: Strong random secret for JWT tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_random_jwt_secret_here

# =============================================================================
# Email Configuration (Production)
# =============================================================================

# Required: Email credentials for sending emails in production
# For FAU: use your FAU email and password
# For Gmail: use your Gmail address and an app password (not your regular password)
EMAIL_SMTP_USER=your.email@fau.de
EMAIL_SMTP_PASS=your_email_password_or_app_password

# Optional: Override default email sender (name and address)
# EMAIL_FROM_NAME="Happy Go Lucky"
# EMAIL_FROM_ADDRESS=dirk.riehle@fau.de

# Optional: Override default SMTP settings
# EMAIL_SMTP_HOST=smtp-auth.fau.de
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_SECURE=true

# =============================================================================
# Optional Features
# =============================================================================

# Optional: GitHub personal access token for code activity feature
VITE_GITHUB_TOKEN=your_github_personal_access_token
